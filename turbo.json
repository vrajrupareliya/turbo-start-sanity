{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "SANITY_API_READ_TOKEN",
    "SANITY_API_WRITE_TOKEN",
    "VERCEL_URL",
    "VERCEL_PROJECT_PRODUCTION_URL",
    "VERCEL_ENV",
    "NODE_ENV",
    "SANITY_STUDIO_PROJECT_ID",
    "SANITY_STUDIO_PRESENTATION_URL",
    "ALGOLIA_API_KEY",
    "ALGOLIA_APP_ID",
    "ALGOLIA_ADMIN_API_KEY",
    "ALGOLIA_INDEX_NAME",
    "SANITY_REVALIDATE_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".sanity/**"],
        "env": [
        "ALGOLIA_API_KEY",
        "ALGOLIA_APP_ID",
        "ALGOLIA_ADMIN_API_KEY",
        "ALGOLIA_INDEX_NAME",
        "SANITY_REVALIDATE_SECRET",
        "SANITY_API_READ_TOKEN",
        "SANITY_API_WRITE_TOKEN"
      ]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "format": {
      "dependsOn": ["transit"]
    },
    "format:check": {
      "dependsOn": ["transit"]
    },
    "check-types": {
      "dependsOn": ["transit"]
    },
    "type": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", ".env*", "tests/**"],
      "outputs": ["playwright-report/**", "test-results/**"]
    }
  }
}
